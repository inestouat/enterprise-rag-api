# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# Embedding Model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Reranker Model
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2



# Chunking Settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Retrieval Settings
TOP_K_RETRIEVE=10
TOP_K_RERANK=5